+def _mask_phone(phone):
+    """Return masked phone for logging (never log full phone)."""
+    if not phone or not isinstance(phone, str):
+        return "***"
+    phone = phone.strip()
+    return ("***" + phone[-4:]) if len(phone) >= 4 else "***"

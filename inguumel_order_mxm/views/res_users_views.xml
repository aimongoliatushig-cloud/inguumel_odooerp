<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_users_form_inherit_warehouse_owner" model="ir.ui.view">
        <field name="name">res.users.form.warehouse_owner</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Mobile / Warehouse Owner" name="warehouse_owner">
                    <group>
                        <field name="x_warehouse_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

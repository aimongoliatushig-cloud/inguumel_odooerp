<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sales tree: show COD status instead of invoice_status for COD orders -->
    <record id="view_order_tree_cod_status" model="ir.ui.view">
        <field name="name">sale.order.tree.cod.status</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_status']" position="replace">
                <field name="x_invoice_status_display" string="Invoice / Payment"/>
            </xpath>
        </field>
    </record>

    <!-- Sale order form: COD info box -->
    <record id="view_order_form_cod_box" model="ir.ui.view">
        <field name="name">sale.order.form.cod.box</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="COD (Cash on Delivery)" invisible="x_payment_method != 'cod'">
                    <field name="x_payment_method" invisible="1"/>
                    <field name="x_cod_confirmed" readonly="1"/>
                    <field name="x_cod_confirmed_at" readonly="1"/>
                    <field name="x_cod_confirmed_by" readonly="1"/>
                    <field name="x_cod_amount" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- COD Cash Report: list of COD orders, no invoices -->
    <record id="view_order_tree_cod_report" model="ir.ui.view">
        <field name="name">sale.order.tree.cod.report</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <list string="COD Cash Report" create="0" delete="0">
                <field name="name"/>
                <field name="date_order"/>
                <field name="warehouse_id"/>
                <field name="partner_id"/>
                <field name="x_phone_primary" string="Phone"/>
                <field name="amount_total"/>
                <field name="x_cod_amount"/>
                <field name="x_cod_confirmed"/>
                <field name="x_cod_confirmed_at"/>
                <field name="x_cod_confirmed_by"/>
                <field name="mxm_delivery_status"/>
            </list>
        </field>
    </record>

    <record id="action_cod_cash_report" model="ir.actions.act_window">
        <field name="name">COD Cash Report</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list</field>
        <field name="domain">[('x_payment_method', '=', 'cod')]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No COD orders</p>
            <p>COD orders only. Use filters for date, warehouse, confirmed/unconfirmed. No invoice created by driver confirm.</p>
        </field>
    </record>

    <record id="action_cod_cash_report_view_list" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_cod_cash_report"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_order_tree_cod_report"/>
        <field name="sequence">1</field>
    </record>

    <menuitem id="menu_cod_cash_report"
              name="COD Cash Report"
              parent="inguumel_order_mxm.menu_inguumel_root"
              action="action_cod_cash_report"
              sequence="50"/>
</odoo>

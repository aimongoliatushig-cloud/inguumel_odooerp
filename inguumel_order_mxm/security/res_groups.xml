<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_inguumel_order" model="ir.module.category">
        <field name="name">Inguumel Order</field>
    </record>
    <!-- Odoo 19: category lives on res.groups.privilege; res.groups has privilege_id -->
    <record id="res_groups_privilege_warehouse_owner" model="res.groups.privilege">
        <field name="name">Warehouse Owner</field>
        <field name="category_id" ref="module_category_inguumel_order"/>
    </record>
    <record id="group_warehouse_owner" model="res.groups">
        <field name="name">Warehouse Owner</field>
        <field name="privilege_id" ref="res_groups_privilege_warehouse_owner"/>
        <field name="comment">Users with warehouse scope (x_warehouse_ids). Used with Driver group for driver app; can also be manager without Driver.</field>
    </record>
    <!-- Driver: users who use the Driver app to set delivery status. Auth login returns role=driver when in this group. -->
    <record id="res_groups_privilege_driver" model="res.groups.privilege">
        <field name="name">Driver</field>
        <field name="category_id" ref="module_category_inguumel_order"/>
    </record>
    <record id="group_driver" model="res.groups">
        <field name="name">Driver</field>
        <field name="privilege_id" ref="res_groups_privilege_driver"/>
        <field name="comment">Driver app: login returns role=driver; can call GET/POST /api/v1/driver/orders/&lt;id&gt;/delivery and .../delivery/status.</field>
    </record>
    <!-- Cashier / Cash Confirm: only these users (or system) can POST cash-confirm for COD orders. Drivers cannot set paid. -->
    <record id="res_groups_privilege_cash_confirm" model="res.groups.privilege">
        <field name="name">Cash Confirm</field>
        <field name="category_id" ref="module_category_inguumel_order"/>
    </record>
    <record id="group_cash_confirm" model="res.groups">
        <field name="name">Cash Confirm (Cashier)</field>
        <field name="privilege_id" ref="res_groups_privilege_cash_confirm"/>
        <field name="comment">Cashier/POS: can confirm COD cash received (POST /api/v1/orders/&lt;id&gt;/cash-confirm). Required for COD flow with separate Driver and Cashier.</field>
    </record>
</odoo>

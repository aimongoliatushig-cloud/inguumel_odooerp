<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_inguumel_credit_repayment_wizard_form" model="ir.ui.view">
    <field name="name">inguumel.credit.repayment.wizard.form</field>
    <field name="model">inguumel.credit.repayment.wizard</field>
    <field name="arch" type="xml">
      <form string="Зээлийн төлөлт бүртгэх">
        <group>
          <field name="loan_id"/>
          <field name="amount"/>
          <field name="currency_id" invisible="1"/>
          <field name="date"/>
          <field name="notes"/>
          <field name="post_to_accounting"/>
        </group>
        <footer>
          <button name="action_confirm" string="Төлөлт бүртгэх" type="object" class="btn-primary"/>
          <button string="Буцах" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_inguumel_credit_repayment_wizard" model="ir.actions.act_window">
    <field name="name">Зээлийн төлөлт бүртгэх</field>
    <field name="res_model">inguumel.credit.repayment.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="binding_model_id" ref="model_inguumel_credit_loan"/>
  </record>
</odoo>
